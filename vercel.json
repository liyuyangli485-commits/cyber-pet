{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "genaisennao_2/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/chat.html", "dest": "/chat.html" },
    { "src": "/avatar\\.png", "dest": "/avatar.png" },
    { "src": "/genaisennao_2/(.*)", "dest": "/genaisennao_2/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
